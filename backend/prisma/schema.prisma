generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  email
  google
  apple
}

enum CategoryType {
  income
  expense
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String?
  firstName      String?
  lastName       String?
  profilePhoto   String?
  provider       AuthProvider  @default(email)
  providerUserId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]
  categories     Category[]
  creditCards    CreditCard[]
  creditScores   CreditScoreSnapshot[]
  investments    Investment[]
  recurringItems RecurringTransaction[]
}

model Category {
  id        String       @id @default(cuid())
  name      String
  type      CategoryType
  icon      String?
  isSystem  Boolean      @default(false)
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([name, type, userId])
}

model Transaction {
  id             String   @id @default(cuid())
  title          String
  description    String?
  amount         Decimal  @db.Decimal(12, 2)
  category       String
  date           DateTime
  isIncome       Boolean
  selectedCardId String?
  isInstallment  Boolean  @default(false)
  transactionType String  @default("standard")
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, date])
}

model CreditCard {
  id                     String   @id
  name                   String
  lastFourDigits         String
  cardholderNameOverride String?
  isActive               Boolean  @default(true)
  limit                  Decimal  @db.Decimal(12, 2)
  availableLimit         Decimal  @db.Decimal(12, 2)
  dueDay                 Int
  statementDay           Int
  paymentGraceDays       Int
  colorHex               String
  shapeKey               String
  installments           Json
  futurePeriodPayments   Json
  userId                 String
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId, updatedAt])
}

model CreditScoreSnapshot {
  id                   String   @id
  createdAt            DateTime
  score                Int
  totalLimit           Decimal  @db.Decimal(12, 2)
  availableLimit       Decimal  @db.Decimal(12, 2)
  currentStatementDebt Decimal  @db.Decimal(12, 2)
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt            DateTime @updatedAt

  @@index([userId, createdAt])
}

model Investment {
  id           String   @id
  title        String
  type         String
  principal    Decimal  @db.Decimal(12, 2)
  currentValue Decimal  @db.Decimal(12, 2)
  maturityRate Decimal? @db.Decimal(8, 4)
  monthlyYield Decimal? @db.Decimal(12, 2)
  termDays     Int?
  openedAt     DateTime?
  symbol       String?
  note         String?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, updatedAt])
}

model RecurringTransaction {
  id             String   @id
  title          String
  category       String
  amount         Decimal  @db.Decimal(12, 2)
  dayOfMonth     Int
  isIncome       Boolean
  isSubscription Boolean  @default(false)
  note           String?
  startDate      DateTime
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, dayOfMonth])
}
